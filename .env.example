# ── Required (LLM) ─────────────────────────────────────────────────────────
# Groq API key for risk explanations and RAG (https://console.groq.com)
GROQ_API_KEY=

# ── Required for Telegram alerts ───────────────────────────────────────────
# Create a bot via @BotFather, then get chat_id from @userinfobot
CAREWATCH_BOT_TOKEN=
CAREWATCH_CHAT_ID=

# ── Optional ───────────────────────────────────────────────────────────────
# Comma-separated CORS origins for the API (default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Set to "production" to enable production behaviour (e.g. stricter error handling)
# ENV=development

# Override target resident when running pipeline (default: resident_0000)
# TARGET_RESIDENT=resident_0000

# ── LangSmith observability (auto-traces LangGraph) ─────────────────────
# Get your key from https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=carewatch-razer
